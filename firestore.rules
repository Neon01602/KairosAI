rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net - default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserId(uid) {
      return uid is string && uid.size() >= 10 && uid.size() <= 64 && uid.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    // --- TASKS COLLECTION ---
    match /tasks/{taskId} {
      allow get: if isValidId(taskId) && (resource.data.userId == request.auth.uid || (request.auth == null && resource.data.userId != null));
      allow list: if (request.auth != null && resource.data.userId == request.auth.uid) || (request.auth == null && resource.data.userId != null);
      allow create: if isValidId(taskId)
        && isValidUserId(request.resource.data.userId)
        && (request.auth == null || request.resource.data.userId == request.auth.uid)
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200;
      allow update: if isValidId(taskId)
        && isValidUserId(request.resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && (request.auth == null || resource.data.userId == request.auth.uid);
      allow delete: if isValidId(taskId) && (resource.data.userId == request.auth.uid || (request.auth == null && resource.data.userId != null));
    }

    // --- BLOCKERS COLLECTION ---
    match /blockers/{blockerId} {
      allow get: if isValidId(blockerId) && (resource.data.userId == request.auth.uid || (request.auth == null && resource.data.userId != null));
      allow list: if (request.auth != null && resource.data.userId == request.auth.uid) || (request.auth == null && resource.data.userId != null);
      allow create: if isValidId(blockerId)
        && isValidUserId(request.resource.data.userId)
        && (request.auth == null || request.resource.data.userId == request.auth.uid)
        && request.resource.data.taskTitle is string;
      allow update: if isValidId(blockerId)
        && isValidUserId(request.resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && (request.auth == null || resource.data.userId == request.auth.uid);
      allow delete: if isValidId(blockerId) && (resource.data.userId == request.auth.uid || (request.auth == null && resource.data.userId != null));
    }

    // --- AUTOPSIES COLLECTION ---
    match /autopsies/{autopsyId} {
      allow get: if isValidId(autopsyId) && (resource.data.userId == request.auth.uid || (request.auth == null && resource.data.userId != null));
      allow list: if (request.auth != null && resource.data.userId == request.auth.uid) || (request.auth == null && resource.data.userId != null);
      allow create: if isValidId(autopsyId)
        && isValidUserId(request.resource.data.userId)
        && (request.auth == null || request.resource.data.userId == request.auth.uid)
        && request.resource.data.taskTitle is string;
      allow update: if isValidId(autopsyId)
        && isValidUserId(request.resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && (request.auth == null || resource.data.userId == request.auth.uid);
      allow delete: if isValidId(autopsyId) && (resource.data.userId == request.auth.uid || (request.auth == null && resource.data.userId != null));
    }

    // --- HABITS COLLECTION ---
    match /habits/{habitId} {
      allow get: if isValidId(habitId) && (resource.data.userId == request.auth.uid || (request.auth == null && resource.data.userId != null));
      allow list: if (request.auth != null && resource.data.userId == request.auth.uid) || (request.auth == null && resource.data.userId != null);
      allow create: if isValidId(habitId)
        && isValidUserId(request.resource.data.userId)
        && (request.auth == null || request.resource.data.userId == request.auth.uid)
        && request.resource.data.name is string;
      allow update: if isValidId(habitId)
        && isValidUserId(request.resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && (request.auth == null || resource.data.userId == request.auth.uid);
      allow delete: if isValidId(habitId) && (resource.data.userId == request.auth.uid || (request.auth == null && resource.data.userId != null));
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read, write: if isValidId(userId);
    }
  }
}
